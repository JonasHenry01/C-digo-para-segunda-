## Buscar

```javascript
function buscarLivro(){

    const nome = document.getElementById("nomeLivro").value;

    const livro = biblioteca.buscar(nome);

    if(livro){

        alert(`Livro encontrado!

${livro.nome}

Autor: ${livro.autor}

Ano: ${livro.ano}

Estoque: ${livro.estoque}`);

    }

}
```

