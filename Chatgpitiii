# Adaptando seu JavaScript

Crie uma função para atualizar a lista na tela.

```javascript
function atualizarTela(){

    const lista = document.getElementById("listaLivros");

    lista.innerHTML="";

    biblioteca.livros.forEach(livro=>{

        lista.innerHTML+=`

        <div class="card">

        <h3>${livro.nome}</h3>

        <p><strong>Autor:</strong> ${livro.autor}</p>

        <p><strong>Ano:</strong> ${livro.ano}</p>

        <p><strong>Gênero:</strong> ${livro.genero}</p>

        <p><strong>Estoque:</strong> ${livro.estoque}</p>

        <p><strong>Alugado:</strong> ${livro.vezesAlugado} vezes</p>

        </div>

        `;

    });

}
```

---

## Adicionar livro

```javascript
function adicionarLivro(){

    biblioteca.adicionarLivros(

        document.getElementById("nome").value,

        document.getElementById("autor").value,

        Number(document.getElementById("ano").value),

        document.getElementById("genero").value,

        Number(document.getElementById("estoque").value)

    );

    atualizarTela();

}
```

---

## Alugar

```javascript
function alugarLivro(){

    const nome = document.getElementById("nomeLivro").value;

    biblioteca.alugar(nome);

    atualizarTela();

}
```

